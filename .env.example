# AVideo server URL (must end with /)
AVIDEO_SERVER_URL=https://your-avideo-site.example.com/

# Credentials (plain text; encrypted by the server on first login)
AVIDEO_USERNAME=admin
AVIDEO_PASSWORD=your_password_here

# Video category ID to assign to imported videos (0 = default/uncategorised)
AVIDEO_CATEGORIES_ID=0

# Directory where downloaded and encoded files are kept during processing
AVIDEO_OUTPUT_DIR=output

# Set to "true" to keep encoded files on disk after a successful upload
AVIDEO_KEEP_FILES=false

# Set to "false" to disable SSL certificate verification (useful for self-signed certs)
AVIDEO_SSL_VERIFY=true

# Override the ID the encoder sends as streamers_id (usually 0 is fine)
AVIDEO_STREAMERS_ID=0

# Path overrides – only needed if ffmpeg/ffprobe/yt-dlp are not on your PATH
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
# YTDLP_BIN=yt-dlp
